{
  "name": "@x402/ton",
  "version": "0.1.0",
  "description": "TON blockchain implementation for x402 payment protocol - USDT on TON",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./dist/client.js": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js"
    },
    "./dist/server.js": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js"
    },
    "./dist/facilitator.js": {
      "types": "./dist/facilitator/index.d.ts",
      "import": "./dist/facilitator/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "node --test tests/**/*.test.mjs",
    "lint": "eslint src --ext .ts"
  },
  "keywords": [
    "x402",
    "ton",
    "blockchain",
    "payment",
    "usdt",
    "jetton"
  ],
  "author": "QVAC Project",
  "license": "MIT",
  "dependencies": {
    "@x402/core": "^2.14.0",
    "@ton/core": "^0.63.1",
    "@ton/crypto": "^3.3.0",
    "@ton/ton": "^16.3.0"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "@types/node": "^20.10.0"
  },
  "peerDependencies": {
    "@x402/core": "^2.0.0"
  }
}